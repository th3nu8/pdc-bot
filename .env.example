# Copy this file to .env and fill in your values. Never commit the real .env.

# Required: Bot token from https://discord.com/developers/applications -> Your App -> Bot -> Reset Token
DISCORD_TOKEN=your_bot_token_here

# Optional: Your server (guild) ID. If set, slash commands sync instantly to this
# server instead of taking up to 1 hour to propagate globally. Get it by enabling
# Developer Mode in Discord (User Settings > Advanced), then right-click your
# server icon > Copy Server ID.
GUILD_ID=

# Optional: A role ID that is also allowed to use /give, /take, /setvp, in
# addition to anyone with the Administrator permission. Right-click a role
# in Server Settings > Roles (with Developer Mode on) > Copy Role ID.
VP_ADMIN_ROLE_ID=

# Optional: A channel ID where every /give, /take, and /setvp gets logged.
# Right-click the channel (with Developer Mode on) > Copy Channel ID.
LOG_CHANNEL_ID=

# Optional: Monthly low-VP check. If a member earned fewer than MIN_MONTHLY_VP
# VP in the previous calendar month, the bot posts a notice in
# MONTHLY_ALERT_CHANNEL_ID and pings MONTHLY_ALERT_ROLE_ID. Runs automatically
# at 09:00 UTC on the 1st of each month, or on demand via /testmonthlycheck.
MONTHLY_ALERT_CHANNEL_ID=
MONTHLY_ALERT_ROLE_ID=
MONTHLY_CHECK_ROLE_ID=
MONTHLY_CHECK_EXEMPT_ROLE_ID=
MIN_MONTHLY_VP=4

# Optional: Monthly activity check. On the 1st of each month, the bot posts a
# "# Monthly Activity Check" message in ACTIVITY_CHECK_CHANNEL_ID, pinging every
# role listed in ACTIVITY_CHECK_PING_ROLE_IDS (comma-separated), and reacts with
# ✅ so members can click it. After ACTIVITY_CHECK_DAYS days, it DMs
# ACTIVITY_CHECK_DM_USER_ID a list of everyone who didn't react — excluding
# anyone with ACTIVITY_CHECK_EXEMPT_ROLE_ID, and (if ACTIVITY_CHECK_PING_ROLE_IDS
# is set) only counting members who hold one of the pinged roles.
ACTIVITY_CHECK_CHANNEL_ID=
ACTIVITY_CHECK_PING_ROLE_IDS=
ACTIVITY_CHECK_EXEMPT_ROLE_ID=
ACTIVITY_CHECK_DM_USER_ID=
ACTIVITY_CHECK_DAYS=14
