# Copy this file to .env and fill in your values. Never commit the real .env.

# Required: Bot token from https://discord.com/developers/applications -> Your App -> Bot -> Reset Token
DISCORD_TOKEN=your_bot_token_here

# Optional: Your server (guild) ID. If set, slash commands sync instantly to this
# server instead of taking up to 1 hour to propagate globally. Get it by enabling
# Developer Mode in Discord (User Settings > Advanced), then right-click your
# server icon > Copy Server ID.
GUILD_ID=

# Optional: A role ID that is also allowed to use /give, /take, /setvp, in
# addition to anyone with the Administrator permission. Right-click a role
# in Server Settings > Roles (with Developer Mode on) > Copy Role ID.
VP_ADMIN_ROLE_ID=
